{
	"name": "@juswap/certificate-designer",
	"version": "0.4.1",
	"license": "MIT",
	"description": "A Vue 3 + Konva library for building interactive, drag-and-drop certificate designers with templates, image clipping, export, and dynamic placeholders.",
	"keywords": [
		"vue",
		"vue3",
		"certificate",
		"certificate-designer",
		"canvas",
		"konva",
		"drag-and-drop",
		"designer",
		"template",
		"editor",
		"image-editor",
		"certificate-generator",
		"export-png",
		"export-pdf"
	],
	"type": "module",
	"main": "./dist/certificate-designer.umd.js",
	"module": "./dist/certificate-designer.es.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/certificate-designer.es.js",
			"require": "./dist/certificate-designer.umd.js"
		}
	},
	"files": [
		"dist"
	],
	"peerDependencies": {
		"jspdf": "^4.2.0",
		"konva": "^10.2.0",
		"vue": "^3.0.0",
		"vue-konva": "^3.3.0"
	},
	"peerDependenciesMeta": {
		"jspdf": {
			"optional": true
		}
	},
	"scripts": {
		"dev": "vite",
		"build": "vue-tsc -b && vite build",
		"preview": "vite preview"
	},
	"devDependencies": {
		"jspdf": "^4.2.0",
		"@types/node": "^24.10.1",
		"@vitejs/plugin-vue": "^6.0.2",
		"@vue/tsconfig": "^0.8.1",
		"typescript": "~5.9.3",
		"vite": "^7.3.1",
		"vite-plugin-dts": "^4.5.4",
		"vue-tsc": "^3.1.5"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/palayjoshua1720/vue-certificate-designer"
	},
	"homepage": "https://github.com/palayjoshua1720/vue-certificate-designer",
	"bugs": {
		"url": "https://github.com/palayjoshua1720/vue-certificate-designer/issues"
	}
}
